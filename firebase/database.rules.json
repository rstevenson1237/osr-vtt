{
  "rules": {
    "rooms": {
      "$roomId": {
        "cursors": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        },
        "dragging": {
          ".read": "auth != null",
          "$tokenId": {
            ".write": "auth != null"
          }
        },
        "pings": {
          ".read": "auth != null",
          "$pingId": {
            ".write": "auth != null"
          }
        },
        "mapDraft": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
