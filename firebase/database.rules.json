{
  "rules": {
    "rooms": {
      "$roomId": {
        ".write": "auth != null && !newData.exists()",
        "cursors": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        },
        "dragging": {
          ".read": "auth != null",
          "$tokenId": {
            ".write": "auth != null"
          }
        },
        "pings": {
          ".read": "auth != null",
          "$pingId": {
            ".write": "auth != null"
          }
        },
        "maps": {
          "$mapId": {
            "mapDraft": {
              ".read": "auth != null",
              "$uid": {
                ".write": "auth != null && auth.uid == $uid"
              }
            }
          }
        },
        "yjs": {
          ".read": "auth != null",
          "$docName": {
            ".write": "auth != null"
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
