rules_version = '2';

// Phase 0 v0 rules (Plan §3). Trust model: any authenticated member of a
// room may read/write shared table-state documents. The one hard boundary
// is `gmPrivate/**`, which only the room's GM UID may ever read or write —
// that is the sole mechanism that makes hidden GM information hidden.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isGM(roomId) {
      return signedIn() && roomDoc(roomId).data.gmUid == request.auth.uid;
    }

    function isMember(roomId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }

    // Per-user "My Rooms" convenience index (Master Plan v2, R6.2). A user may
    // only ever read or write their OWN index — never peek at or tamper with
    // anyone else's list of rooms. Best-effort data: it grants no authority
    // (every real access check reads the room doc's `gmUid`/`players` subtree,
    // never this index).
    match /users/{userId}/rooms/{roomId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /rooms/{roomId} {
      // Room creation: the creator becomes GM (gmUid must equal their own uid).
      allow create: if signedIn() && request.resource.data.gmUid == request.auth.uid;
      allow read: if signedIn();
      // Only the GM may edit room-level fields (profileTemplate, difficulty/danger die, etc).
      allow update, delete: if isGM(roomId);

      match /players/{uid} {
        allow read: if signedIn();
        // A player manages their own seat doc; the GM can manage any seat.
        allow write: if signedIn() && (request.auth.uid == uid || isGM(roomId));
      }

      match /profiles/{seatId} {
        allow read: if signedIn();
        // seatId == owning player's uid for v1 (§2.5: writable by the owning seat or the GM).
        allow write: if signedIn() && (request.auth.uid == seatId || isGM(roomId));
      }

      match /tokens/{tokenId} {
        allow read: if signedIn();
        allow write: if isMember(roomId) || isGM(roomId);
      }

      // Groups roster (Phase 2): creation, membership, and the
      // [Map]/[Board]/[Active] toggles are GM controls (Encounter Screen
      // Spec §3, §8 — revealing/activating a group is the referee's call).
      match /groups/{groupId} {
        allow read: if signedIn();
        allow write: if isGM(roomId);
      }

      // Combat tracker (Encounter Screen Spec §10): GM-writable, all-readable.
      match /encounter/{docId} {
        allow read: if signedIn();
        allow write: if isGM(roomId);
      }

      // Legacy flat annotation/symbol collections (pre-v10->v11, R17.3) — kept
      // ONLY so `ensureActiveMap` can read + delete a not-yet-migrated room's
      // data while adopting it into its first `maps/{mapId}` doc (see that
      // method's doc comment). No client ever writes NEW data at these flat
      // paths again. The cellular-only flat collections that used to live
      // here (floorChunks/walls/sightWalls/circleWalls/lights/fogChunks) were
      // deleted at the WI-D pure-rollout cutover along with the rest of the
      // cellular model (`poc/vector-floor/DECISIONS.md`, D1).
      match /drawings/{strokeId} {
        allow read: if signedIn();
        allow write: if isMember(roomId) || isGM(roomId);
      }

      match /symbols/{symbolId} {
        allow read: if signedIn();
        allow write: if isMember(roomId) || isGM(roomId);
      }

      match /mapRooms/{mapRoomId} {
        allow read: if signedIn();
        allow write: if isMember(roomId) || isGM(roomId);
      }

      // Multiple full map builds per session (Master Plan v2, R17.3): the map
      // doc itself (background/grid/measure/gridSettings — create/rename/
      // delete/switch-active are all referee actions) plus its own map
      // subcollections, same trust model each collection had flat under
      // `rooms/{roomId}` before the v10->v11 migration moved them here.
      match /maps/{mapId} {
        allow read: if signedIn();
        allow create, update, delete: if isGM(roomId);

        match /drawings/{strokeId} {
          allow read: if signedIn();
          allow write: if isMember(roomId) || isGM(roomId);
        }

        // Symbol/label authoring (SPEC §2.2) — trust model, same as
        // tokens/drawings above.
        match /symbols/{symbolId} {
          allow read: if signedIn();
          allow write: if isMember(roomId) || isGM(roomId);
        }

        match /mapRooms/{mapRoomId} {
          allow read: if signedIn();
          allow write: if isMember(roomId) || isGM(roomId);
        }

        // Vector Map System (SPEC/DECISIONS in `poc/vector-floor/`) — the
        // ONLY map geometry model (WI-D pure-rollout cutover). Baked-union
        // floor regions, explicit/imported wall segments, and overlay doors.
        // Member-or-GM write, all-readable — same trust model the cellular
        // collections had before they were deleted.
        match /floorRegions/{regionId} {
          allow read: if signedIn();
          allow write: if isMember(roomId) || isGM(roomId);
        }

        match /walls/{wallId} {
          allow read: if signedIn();
          allow write: if isMember(roomId) || isGM(roomId);
        }

        match /doors/{doorId} {
          allow read: if signedIn();
          allow write: if isMember(roomId) || isGM(roomId);
        }
      }

      match /log/{entryId} {
        allow read: if signedIn();
        allow write: if isMember(roomId) || isGM(roomId);
      }

      match /rolls/{rollId} {
        allow read: if signedIn();
        allow write: if isMember(roomId) || isGM(roomId);
      }

      // Shared rolls (Master Plan v2, R3.6): the referee opens/resolves the
      // `current` staging doc; each seat's slot is its own doc, own-uid-or-GM
      // writable — same pattern as `players/{uid}` below, so a player can
      // never touch another seat's staged die.
      match /sharedRoll/{docId} {
        allow read: if signedIn();
        allow write: if isGM(roomId);

        match /slots/{slotId} {
          allow read: if signedIn();
          allow write: if isGM(roomId) || (isMember(roomId) && request.auth.uid == slotId);
        }
      }

      // Saved dice macros (Plan §7 Phase 3): owning player or the GM only,
      // same pattern as profiles (§2.5) — `ownerUid` lives in the doc body
      // (unlike profiles, the doc id isn't the owner's uid). The GM may also
      // create a macro under another uid — needed for `.vttcamp` import
      // (Plan §5, §7 Phase 5) to restore a macro's original owner verbatim.
      match /macros/{macroId} {
        allow read: if signedIn();
        allow create: if signedIn() &&
          (request.resource.data.ownerUid == request.auth.uid || isGM(roomId));
        allow update, delete: if signedIn() &&
          (request.auth.uid == resource.data.ownerUid || isGM(roomId));
      }

      match /tables/{tableId} {
        allow read: if isMember(roomId) || isGM(roomId);
        allow write: if isGM(roomId);
      }

      // Assets activity's "By URL" saved-refs list (Master Plan v2, R7.2):
      // any member (or the GM, for `.vttcamp` import) may save/reuse a
      // pasted URL — same trust model as tokens/drawings above.
      match /assetRefs/{refId} {
        allow read: if signedIn();
        allow write: if isMember(roomId) || isGM(roomId);
      }

      // GM-ONLY. All hidden information (unrevealed fog, blind-drawer results,
      // hidden token notes, etc.) must live under this subtree.
      match /gmPrivate/{docId} {
        allow read, write: if isGM(roomId);
      }
    }
  }
}
