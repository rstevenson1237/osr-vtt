{
  "name": "vector-floor-sandbox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "POC §9.1 in-memory drawing showcase for the Vector Map System spec. NOT part of the pnpm workspace; never imported by apps/ or packages/.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "artifact": "node build-artifact.mjs",
    "verify": "esbuild verify.ts --bundle --platform=node --format=esm --outfile=dist/verify.mjs && node dist/verify.mjs",
    "smoke": "npm run artifact && node smoke.mjs",
    "check": "tsc --noEmit && npm run verify"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "polygon-clipping": "^0.15.7"
  }
}
