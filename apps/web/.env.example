# Firebase web config (Plan §10.2) — not secret, safe to commit once real.
# Leave unset to run against the Emulator Suite with a demo project (Phase 0
# default — see src/lib/firebase/env.ts).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_DATABASE_URL=
# VITE_FIREBASE_APP_ID=

# Set to "false" once a real project + deploy target exist. Defaults to
# emulator mode (true) otherwise.
# VITE_USE_EMULATORS=true

# WI-D (poc/vector-floor/) preview: mounts the Vector Map editor
# (VectorMapView) instead of the cellular MapView for every map in this
# build. One build/config flag, never a per-map field (DECISIONS.md B2) —
# the two map systems coexist pre-cutover. Defaults to "false" (cellular).
# VITE_VECTOR_MAP_EDITOR=true
